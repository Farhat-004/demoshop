# Copy to .env and fill in values
#
# Local MongoDB (Prisma requires a replica set):
#   1. Stop any other MongoDB on port 27017
#   2. cd backend && docker compose up -d
#   3. Use the DATABASE_URL below
#
# MongoDB Atlas already runs as a replica set — use your Atlas URL as-is.

DATABASE_URL="mongodb://127.0.0.1:27017/demoshop?replicaSet=rs0"
AUTH_SECRET="change-me-to-a-secure-random-string"
PORT=3000
FRONTEND_URL="http://localhost:5173"
